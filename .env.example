# ==============================================================
# 002_infrastructure 环境变量配置
# 复制此文件为 .env 并按需修改
# cp .env.example .env
# ==============================================================

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=16MB

# --- Redis ---
# 留空则不需要密码 (开发环境)
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=noeviction

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_PORT=27017

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# --- pgAdmin ---
PGADMIN_EMAIL=admin@infra.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- phpMyAdmin ---
PHPMYADMIN_PORT=5051

# --- Mongo Express ---
MONGO_EXPRESS_PORT=5052

# --- Redis Commander ---
REDIS_COMMANDER_PORT=5053

# --- Portainer ---
PORTAINER_PORT=9000

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=9091

# --- Loki ---
LOKI_PORT=3100

# --- Promtail ---
PROMTAIL_PORT=9080

# --- Alertmanager ---
ALERTMANAGER_PORT=9093
