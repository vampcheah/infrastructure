# ==============================================================
# 002_infrastructure 环境变量配置
# 复制此文件为 .env 并按需修改
# cp .env.example .env
# ==============================================================

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_WORK_MEM=16MB

# --- Redis ---
# 留空则不需要密码 (开发环境)
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=noeviction

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_PORT=27017

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# --- RustFS ---
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# --- pgAdmin ---
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- phpMyAdmin ---
PHPMYADMIN_PORT=5051

# --- Mongo Express ---
MONGO_EXPRESS_PORT=5052

# --- Redis Commander ---
REDIS_COMMANDER_PORT=5053

# --- Portainer ---
PORTAINER_PORT=9002

# --- Smart Backup DB ---
# 时区（ofelia 按此解析 cron 表达式）
TZ=Asia/Kuala_Lumpur
# 备份触发表达式 (ofelia 6 段 cron：秒 分 时 日 月 周；默认每天 03:00:00)
BACKUP_CRON_SCHEDULE=0 0 3 * * *
